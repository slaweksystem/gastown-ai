# --- PostgreSQL ---
# Credentials for the Postgres instance that backs Gitea.
POSTGRES_USER=gitea
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=gitea

# --- Gitea ---
# Public domain and root URL of the Gitea instance.
GITEA_DOMAIN=localhost
GITEA_ROOT_URL=http://localhost:3000/

# Host ports exposed by the Gitea container.
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222

# Disable public sign-ups on the self-hosted instance by default.
GITEA_DISABLE_REGISTRATION=true
